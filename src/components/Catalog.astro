---
import "../assets/index.css";
---

<section class="content-section catalog-section" id="catalogos">
    <div class="section-shell relative-content">
        <p class="section-kicker">INGENIERÍA EN MOVIMIENTO</p>
        <h2>Catálogos por Línea</h2>
        <p class="section-description">Explora nuestras soluciones técnicas de alta precisión. Descarga la ficha técnica o solicita una cotización inmediata.</p>
        
        <div class="catalog-grid reveal-stagger">
            <!-- CARD: Rodamientos -->
            <article class="catalog-card-outer double-bezel-outer-light">
                <div class="catalog-card-inner double-bezel-inner-light">
                    <div class="catalog-visual">
                        <img src="assets/img/cat-rodamientos.png" alt="Rodamientos Industriales Premium" class="catalog-img" width="400" height="220" loading="lazy">
                        <div class="catalog-overlay">
                            <span class="tech-id">SPEC-TRT-001</span>
                        </div>
                    </div>
                    <div class="catalog-content">
                        <div class="catalog-header">
                            <h3>Rodamientos</h3>
                            <span class="catalog-badge">Premium</span>
                        </div>
                        <p>Soluciones SKF, TIMKEN y NSK con alta precisión para aplicaciones críticas.</p>
                        <div class="catalog-specs">
                            <div class="spec-item">
                                <span class="spec-label">SKU</span>
                                <span class="spec-value">+500</span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">REV</span>
                                <span class="spec-value">2026.05</span>
                            </div>
                        </div>
                    </div>
                    <div class="catalog-footer">
                        <a href="assets/pdf/catalogo-rodamientos.pdf" download class="btn--ghost-light">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                            Ficha PDF
                        </a>
                        <a href="https://wa.me/5215500000000?text=Hola%20TRT%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20rodamientos." class="btn--whatsapp">
                            Cotizar
                        </a>
                    </div>
                </div>
            </article>
            
            <!-- CARD 2: Bandas -->
            <article class="catalog-card-outer double-bezel-outer-light">
                <div class="catalog-card-inner double-bezel-inner-light">
                    <div class="catalog-visual">
                        <img src="assets/img/cat-bandas.png" alt="Bandas de Transmisión Industrial" class="catalog-img" width="400" height="220" loading="lazy">
                        <div class="catalog-overlay">
                            <span class="tech-id">SPEC-TRT-002</span>
                        </div>
                    </div>
                    <div class="catalog-content">
                        <div class="catalog-header">
                            <h3>Bandas Industriales</h3>
                            <span class="catalog-badge">Heavy Duty</span>
                        </div>
                        <p>Correas síncronas y de transmisión para máxima eficiencia energética.</p>
                        <div class="catalog-specs">
                            <div class="spec-item">
                                <span class="spec-label">SKU</span>
                                <span class="spec-value">+300</span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">REV</span>
                                <span class="spec-value">2026.05</span>
                            </div>
                        </div>
                    </div>
                    <div class="catalog-footer">
                        <a href="assets/pdf/catalogo-bandas.pdf" download class="btn--ghost-light">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                            Ficha PDF
                        </a>
                        <a href="https://wa.me/5215500000000?text=Hola%20TRT%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20bandas." class="btn--whatsapp">
                            Cotizar
                        </a>
                    </div>
                </div>
            </article>
            
            <!-- CARD 3: Cadenas -->
            <article class="catalog-card-outer double-bezel-outer-light">
                <div class="catalog-card-inner double-bezel-inner-light">
                    <div class="catalog-visual">
                        <img src="assets/img/cat-cadenas.png" alt="Cadenas de Potencia Industrial" class="catalog-img" width="400" height="220" loading="lazy">
                        <div class="catalog-overlay">
                            <span class="tech-id">SPEC-TRT-003</span>
                        </div>
                    </div>
                    <div class="catalog-content">
                        <div class="catalog-header">
                            <h3>Cadenas</h3>
                            <span class="catalog-badge">Potencia</span>
                        </div>
                        <p>Cadenas de rodillos y de ingeniería para transmisión de potencia extrema.</p>
                        <div class="catalog-specs">
                            <div class="spec-item">
                                <span class="spec-label">SKU</span>
                                <span class="spec-value">+250</span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">REV</span>
                                <span class="spec-value">2026.05</span>
                            </div>
                        </div>
                    </div>
                    <div class="catalog-footer">
                        <a href="assets/pdf/catalogo-cadenas.pdf" download class="btn--ghost-light">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                            Ficha PDF
                        </a>
                        <a href="https://wa.me/5215500000000?text=Hola%20TRT%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20cadenas." class="btn--whatsapp">
                            Cotizar
                        </a>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>
