---
import "../assets/index.css";
---

<section class="content-section audience-section" id="audiencia">
    <div class="section-shell">
        <p class="section-kicker">SOLUCIONES A TU MEDIDA</p>
        <h2>Atención especializada para cada necesidad</h2>
        <div class="audience-grid">
            <article
                class="audience-card audience-card--business"
                id="empresas"
                aria-labelledby="empresas-heading"
            >
                <div class="audience-card-header">
                    <span class="audience-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            width="28"
                            height="28"
                            aria-hidden="true"
                            focusable="false"
                        >
                            <path
                                d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                            ></path>
                            <polyline points="9 22 9 12 15 12 15 22"></polyline>
                            <line x1="9" y1="3" x2="9" y2="9"></line>
                        </svg>
                    </span>
                    <span class="audience-badge">VOLUMEN</span>
                </div>
                <h3 id="empresas-heading">Soy empresa / compro a volumen</h3>
                <p>
                    Atención para talleres, refaccionarias, flotillas y compras
                    recurrentes con cotización rápida.
                </p>
                <ul class="audience-benefits">
                    <li>Cotización en &lt;10 min</li>
                    <li>Descuentos por volumen</li>
                    <li>Asesor dedicado</li>
                </ul>
                <div class="audience-card-footer">
                    <a
                        href="https://wa.me/5215500000000?text=Hola%20TRT%2C%20soy%20empresa%20y%20quiero%20cotizar%20a%20volumen."
                        class="btn--whatsapp"
                        aria-label="Cotizar por WhatsApp como empresa o taller"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                            focusable="false"
                            ><path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.966-.273-.099-.471-.148-.67.15-.198.297-.768.965-.94 1.164-.173.198-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.787-1.48-1.76-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.151-.173.2-.298.3-.497.099-.198.05-.371-.025-.52-.074-.148-.669-1.612-.916-2.207-.242-.58-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.793.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.148.198 2.095 3.2 5.077 4.487.71.306 1.263.489 1.694.626.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.414.248-.694.248-1.29.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.002-5.448 4.436-9.883 9.887-9.883 2.64 0 5.122 1.03 6.988 2.899 1.868 1.868 2.9 4.352 2.899 6.991-.003 5.45-4.437 9.885-9.89 9.885"
                            ></path></svg
                        >
                        Cotizar como empresa
                    </a>
                </div>
            </article>
            <article
                class="audience-card audience-card--individual"
                id="particulares"
                aria-labelledby="particulares-heading"
            >
                <div class="audience-card-header">
                    <span class="audience-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            width="28"
                            height="28"
                            aria-hidden="true"
                            focusable="false"
                        >
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                            ></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </span>
                    <span class="audience-badge">UNITARIO</span>
                </div>
                <h3 id="particulares-heading">
                    Soy particular / busco una pieza
                </h3>
                <p>
                    Te ayudamos a encontrar la pieza exacta aunque solo
                    necesites una unidad.
                </p>
                <ul class="audience-benefits">
                    <li>Búsqueda asistida</li>
                    <li>Equivalencias incluidas</li>
                    <li>Envío a todo México</li>
                </ul>
                <div class="audience-card-footer">
                    <a
                        href="https://wa.me/5215500000000?text=Hola%20TRT%2C%20busco%20una%20pieza%20espec%C3%ADfica%20y%20necesito%20asesor%C3%ADa."
                        class="btn--whatsapp"
                        aria-label="Buscar mi pieza por WhatsApp con asesoría"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                            focusable="false"
                            ><path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.966-.273-.099-.471-.148-.67.15-.198.297-.768.965-.94 1.164-.173.198-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.787-1.48-1.76-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.151-.173.2-.298.3-.497.099-.198.05-.371-.025-.52-.074-.148-.669-1.612-.916-2.207-.242-.58-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.793.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.148.198 2.095 3.2 5.077 4.487.71.306 1.263.489 1.694.626.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.414.248-.694.248-1.29.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.002-5.448 4.436-9.883 9.887-9.883 2.64 0 5.122 1.03 6.988 2.899 1.868 1.868 2.9 4.352 2.899 6.991-.003 5.45-4.437 9.885-9.89 9.885"
                            ></path></svg
                        >
                        Buscar mi pieza
                    </a>
                </div>
            </article>
        </div>
    </div>
</section>
