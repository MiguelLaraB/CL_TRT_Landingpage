</style>

<script>
    const setupCopyButtons = () => {
        const copyBtns = document.querySelectorAll('.copy-email-btn');
        copyBtns.forEach(btn => {
            // Remove existing listener to avoid duplicates if setup is called multiple times
            const newBtn = btn.cloneNode(true);
            btn.parentNode.replaceChild(newBtn, btn);
            
            newBtn.addEventListener('click', async () => {
                const email = newBtn.getAttribute('data-email');
                if (email) {
                    try {
                        await navigator.clipboard.writeText(email);
                        const originalText = newBtn.getAttribute('data-original-text') || newBtn.textContent;
                        if (!newBtn.hasAttribute('data-original-text')) {
                            newBtn.setAttribute('data-original-text', originalText);
                        }
                        newBtn.textContent = '¡Copiado!';
                        newBtn.classList.add('copied');
                        setTimeout(() => {
                            newBtn.textContent = originalText;
                            newBtn.classList.remove('copied');
                        }, 2000);
                    } catch (err) {
                        console.error('Error al copiar: ', err);
                    }
                }
            });
        });
    };

    // Initialize on load
    setupCopyButtons();
    
    // Support for Astro view transitions
    document.addEventListener('astro:page-load', setupCopyButtons);
</script>
