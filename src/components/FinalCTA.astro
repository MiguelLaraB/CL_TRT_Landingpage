---
import "../assets/index.css";
---

<section class="content-section final-cta-section" aria-labelledby="final-cta-title">
    <div class="section-shell final-cta-shell">
        <div class="final-cta-grid">
            <div class="final-cta-copy" data-reveal>
                <p class="section-kicker final-cta-kicker">Soporte técnico especializado</p>
                <h2 class="final-cta-title" id="final-cta-title">Tu proyecto merece <span>precisión industrial.</span></h2>
                <p class="final-cta-lede">Mándanos foto, medida, código o lista completa. Validamos existencia, equivalencias y ruta de entrega para que compres la pieza correcta sin fricción.</p>

                <div class="final-cta-proof-row" role="list" aria-label="Indicadores de servicio TRT">
                    <div class="proof-chip" role="listitem">
                        <strong>10 min</strong>
                        <span>Cotización express</span>
                    </div>
                    <div class="proof-chip" role="listitem">
                        <strong>50k+</strong>
                        <span>Piezas en stock</span>
                    </div>
                    <div class="proof-chip" role="listitem">
                        <strong>MX</strong>
                        <span>Envío nacional</span>
                    </div>
                </div>
            </div>

            <div class="final-cta-panel-wrap" data-reveal data-reveal-delay="120">
                <article class="final-quote-panel" aria-label="Flujo de cotización por WhatsApp">
                    <div class="final-quote-core">
                        <header class="quote-panel-header">
                            <span class="hub-status"><span class="pulse-dot"></span> Línea TRT activa</span>
                            <span class="quote-panel-code">RFQ / TRT-24</span>
                        </header>

                        <div class="quote-docket">
                            <span class="docket-label">Flujo recomendado</span>
                            <ol class="quote-steps">
                                <li>
                                    <span class="quote-step-index">01</span>
                                    <span>Comparte foto, medida o código de la pieza.</span>
                                </li>
                                <li>
                                    <span class="quote-step-index">02</span>
                                    <span>Validamos stock y equivalencias técnicas.</span>
                                </li>
                                <li>
                                    <span class="quote-step-index">03</span>
                                    <span>Confirmas entrega local o envío nacional.</span>
                                </li>
                            </ol>
                        </div>

                        <p class="quote-support-note">Atendemos compras por volumen, flotillas y piezas únicas con asesoría técnica.</p>

                        <a href="https://wa.me/5215500000000?text=Hola%20TRT%2C%20te%20comparto%20mi%20lista%20de%20piezas%20para%20cotizar%20hoy." class="btn--whatsapp final-cta-button" aria-label="Abrir WhatsApp para mandar lista de piezas a TRT">
                            <span>Mandar lista por WhatsApp</span>
                            <span class="btn-icon-wrapper">
                                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.966-.273-.099-.471-.148-.67.15-.198.297-.768.965-.94 1.164-.173.198-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.787-1.48-1.76-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.151-.173.2-.298.3-.497.099-.198.05-.371-.025-.52-.074-.148-.669-1.612-.916-2.207-.242-.58-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.793.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.148.198 2.095 3.2 5.077 4.487.71.306 1.263.489 1.694.626.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.414.248-.694.248-1.29.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.002-5.448 4.436-9.883 9.887-9.883 2.64 0 5.122 1.03 6.988 2.899 1.868 1.868 2.9 4.352 2.899 6.991-.003 5.45-4.437 9.885-9.89 9.885"></path>
                                </svg>
                            </span>
                        </a>
                        <p class="cta-footer-note">Respuesta prioritaria en horario hábil. Sin formularios largos.</p>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>
