---
interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title = "TRT | Transmisiones y Rodamientos de Tlalnepantla",
	description = "Venta y suministro de transmisiones, rodamientos y refacciones automotrices en CDMX, Río Blanco. Atención personalizada, calidad y entrega rápida.",
	image = "/seo-banner.webp",
} = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/trt-logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Datos estructurados -->
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "AutoPartsStore",
				name: "TRT - Transmisiones y Rodamientos de Tlalnepantla",
				url: "https://transmisionesyrodamientostlanepantla.com.mx",
				description: description,
				image: "https://transmisionesyrodamientostlanepantla.com.mx/seo-banner.webp",
				telephone: "+56 2016 2470",
				department: [
					{
						"@type": "AutoPartsStore",
						name: "TRT CDMX",

						telephone: ["+52 56 2016 2470", "+52 55 7675 6775"],
						email: [
							"ventastrt@live.com",
							"trt.ventas1@transmisionesyrodamientostlalnepantla.com.mx",
							"ventas3trt@hotmail.com",
						],

						address: {
							"@type": "PostalAddress",
							streetAddress:
								"Turin #12 MZ.31 Colonia Izcalli Piramide",
							addressLocality: "Tlalnepantla",
							addressRegion: "Estado de México",
							postalCode: "54140",
							addressCountry: "MX",
						},
					},
					{
						"@type": "AutoPartsStore",
						name: "TRT Río Blanco",

						telephone: [
							"+52 271 133 9376",
							"+52 272 217 8982",
							"+52 272 446 0944",
						],
						email: ["ventas6trt@hotmail.com"],

						address: {
							"@type": "PostalAddress",
							streetAddress:
								"Camino Nacional #319, Colonia Vicente Guerrero",
							addressLocality: "Río Blanco",
							addressRegion: "Veracruz",
							postalCode: "94735",
							addressCountry: "MX",
						},
					},
				],
			})}
		/>

		<!-- Evita contenido duplicado -->
		<link rel="canonical" href={Astro.url.href} />

		<!-- Indica a Google que indexe -->
		<meta name="robots" content="index, follow" />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="es_MX" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<link rel="icon" href="/trt-logo.png" />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600&display=swap"
			rel="stylesheet"
		/>
	</head>

	<body>
		<slot />
		<script is:inline src="/main.js?v=1.2"></script>
	</body>
</html>

<style is:global>
	:root {
		--font-family: "Plus Jakarta Sans", sans-serif;
		--header-height: 80px;
	}

	html {
		scroll-behavior: smooth;
		scroll-padding-top: var(--header-height);
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: var(--font-family);
	}

	/* Estilos base si son necesarios */
</style>
